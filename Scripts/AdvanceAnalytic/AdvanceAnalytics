--=======================================
--	DATA SEGMENTATION>>Measure By Measure
--=======================================

-- Total Products By Sale Range> Count product in the Sale range.

WITH Product_Segment AS
(
SELECT
	ProductKey,
	Name AS ProductName,
	Cost,
	CASE NTILE(3) OVER (ORDER BY cost DESC) --NTILE GIVES BALANCE SEGMENTS
        WHEN 1 THEN 'High '
        WHEN 2 THEN 'Medium'
        WHEN 3 THEN 'Low'
	END AS CostRange
FROM Gold.VW_Sales_Details
)

SELECT 
	CostRange,
	COUNT(DISTINCT ProductKey) AS TotalProducts
FROM Product_Segment
GROUP BY CostRange
ORDER BY TotalProducts DESC;

--GROUP CUSTOMER BY THEIR SPENDING

WITH CustomerSpending AS
(
    SELECT
       FullName AS CustomerName,
       SUM(OrderAmount) AS TotalSpending
    FROM Gold.VW_Sales_Details
    GROUP BY FullName
)
SELECT
    CustomerName,
    TotalSpending,
    CASE NTILE(3) OVER (ORDER BY TotalSpending DESC)
        WHEN 1 THEN 'High Spender'
        WHEN 2 THEN 'Medium Spender'
        WHEN 3 THEN 'Low Spender'
    END AS CustomerSegment
FROM CustomerSpending

