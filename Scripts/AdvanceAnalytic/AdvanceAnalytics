--Which Category contribute the most to overall Sales

SELECT
	ProductCategorY,
	ROUND(SUM(OrderAmount),2) AS TotalSales
FROM Gold.VW_Sales_Details
GROUP BY ProductCategory

--===================
SELECT
	ProductCategory,
	OrderAmount,
	SUM(OrderAmount) OVER() AS TotalSales,
	CONCAT(ROUND(CAST(OrderAmount AS DECIMAL(18,2)) / SUM(OrderAmount) OVER() * 100,2),'%') AS PercentageOfTotal
FROM Gold.VW_Sales_Details
GROUP BY ProductCategory, OrderAmount
ORDER BY OrderAmount


