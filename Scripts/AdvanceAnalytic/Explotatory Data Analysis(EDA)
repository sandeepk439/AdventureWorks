--Explore all objects in the database

SELECT * FROM INFORMATION_SCHEMA.TABLES

--Explore all coloums in the database

SELECT * FROM INFORMATION_SCHEMA.COLUMNS

--======================
--DIMENTION EXPLORATION
--=====================
--Explore all countries Customer comes from.

SELECT DISTINCT COUNTRY FROM Silver.Ter_info

--Explore all categories "The major division"

SELECT 
	DISTINCT ProductCategory, ProductSubCategory, ProductName
FROM Gold.VW_Product_Details
ORDER BY 1, 2, 3

--=================
--Date Exploration
--=================
--First and last date of the Sale order.
-- Month of Sales available

SELECT 
	MIN(OrderDate) AS FirstOrderDate,
	MAX(OrderDate) AS LastOrderDate,
	DATEDIFF(MONTH, MIN(OrderDate),MAX(OrderDate)) AS TotalMonthSales
FROM Gold.VW_SALES

--Oldest and Youngest Customer
SELECT
	MAX(BirthDate) AS YoungestCustomer,
	DATEDIFF(YEAR, MAX(BirthDate), GETDATE()) AS YoungestAge,
	MIN(BirthDate) AS OldestCustomer,
	DATEDIFF(YEAR, MIN(BirthDate), GETDATE()) AS OlderstAge
FROM Silver.Cus_Info

--================================
--MEASURE EXPLORATION(BIG NUMBERS)
--================================
-- FIND THE TOTAL SALES
SELECT SUM(OrderQuantity*Price) AS TotalSales FROM Gold.VW_Sales_Details

--HOW MANY ITEMS ARE SOLD
SELECT SUM(OrderQuantity) AS TotalItemSold FROM Gold.VW_Sales_Details

--TO FIND AVG SELLING PRICE
SELECT AVG(Price) AS AvgSellingPrice FROM Gold.VW_Sales_Details

--TO FIND TOTAL NUMBER OF ORDERS
SELECT COUNT(OrderNumber) AS TotalOrders FROM Gold.VW_Sales_Details
SELECT COUNT(DISTINCT(OrderNumber)) AS TotalUniqueOrders FROM Gold.VW_Sales_Details

--TO FIND TOTAL NUMBER OF PRODUCTS
SELECT COUNT(DISTINCT(ProductName)) FROM Gold.VW_Product_Details
SELECT COUNT(ProductName) FROM Gold.VW_Product_Details

--TO FIND TOTAL NUMBER OF CUSTOMERS
SELECT COUNT(FirstName+' '+LastName) FROM Silver.Cus_Info
SELECT COUNT(DISTINCT(FirstName+' '+LastName)) FROM Silver.Cus_Info

--TO FIND TOTAL NUMBER OF CUSTOMERS WHO PLACED ORDRERS.
SELECT COUNT(CustomerKey) FROM Gold.vw_Sales
SELECT COUNT(DISTINCT(CustomerKey)) FROM Gold.vw_Sales

--Generate a Report that shows all key metrics of the Business
SELECT 'Total Sales' AS MeasureName, SUM(OrderQuantity*Price) AS MeasureValue FROM Gold.vw_Sales_Details
UNION ALL
SELECT 'Total Quantity' AS MeasureName, SUM(OrderQuantity) AS MeasureValue FROM Gold.vw_Sales_Details
UNION ALL
SELECT 'Avg Price' AS MeasureName, AVG(Price) AS MeasureValue FROM Gold.vw_Sales_Details
UNION ALL
SELECT 'Total Num of Order' AS MeasureName, COUNT(DISTINCT(OrderNumber)) AS MeasureValue FROM Gold.vw_Sales_Details
UNION ALL
SELECT 'Total Num Of Products' AS MeasureName, COUNT(DISTINCT Name) AS MeasureValue FROM Gold.vw_Sales_Details
UNION ALL
SELECT 'Total Num Of Customers' AS MeasureName, COUNT(DISTINCT CustomerKey) AS MeasureValue FROM Silver.Cus_Info

--===============
--	MEASURES
--==============
--Find Total Customers by Countries
SELECT T.Country,COUNT(DISTINCT s.CustomerKey) TotalCustomers FROM Gold.VW_Sales S
LEFT JOIN Silver.Ter_info T ON T.SalesTerritoryKey=S.TerritoryKey
GROUP BY T.Country

--Find Total Customers by Genders
SELECT Gender,COUNT(DISTINCT CustomerKey) AS TotalCustomer FROM Silver.Cus_Info GROUP BY Gender

--Find Total Products by Category
SELECT ProductCategory, COUNT(ProductName) AS NumberOfProducts FROM Gold.VW_Product_Details GROUP BY ProductCategory

--What is the AVG cost in each Category
SELECT ProductCategory, AVG(Cost) AS AvgCost FROM Gold.vw_Product_Details GROUP BY ProductCategory

--What is the Total Revenue generated by each Category
SELECT ProductCategory,SUM(Price*OrderQuantity) AS TotalRevenue FROM Gold.VW_Sales_Details GROUP BY ProductCategory

--Find Total Revenue generated by each Customer
SELECT FullName,SUM(OrderAmount) TotalRevenue  FROM Gold.vw_sales_Details GROUP BY FullName ORDER BY FullName

--What is the distribution of sold items across countries.
SELECT Country, COUNT(Name) TotalSoldItems FROM Gold.VW_Sales_Details GROUP BY Country

--================================
--	Ranking>> Rank by sum(measures)
--================================
--Which Top 5 Products generates the highest revenue
SELECT Top 5 
	Name AS ProductName,
	SUM(OrderAmount) AS TotalRevenue 
FROM Gold.vw_Sales_Details 
GROUP BY Name 
ORDER BY TotalRevenue DESC

--Rank countries by Sales
SELECT Country,
	SUM(OrderAmount) AS TotalSales,
	ROW_NUMBER() OVER (ORDER BY SUM(OrderAmount) DESC) as 'Rank' from Gold.vw_Sales_details GROUP BY Country

--The 3 customers fewest order placed
SELECT TOP 3 s.CustomerKey AS Customer,
C.FirstName+' '+C.LastName AS CustomerName,
SUM(s.OrderQuantity) AS OrderQuantity 
FROM Gold.VW_SALES S
LEFT JOIN Silver.Cus_Info C ON S.CustomerKey=C.CustomerKey
GROUP BY S.CustomerKey,C.FirstName+' '+C.LastName
ORDER BY SUM(S.OrderQuantity)

-- Top 3 Customer with higest order placed
SELECT TOP 3 s.CustomerKey AS Customer,
C.FirstName+' '+C.LastName AS CustomerName,
SUM(s.OrderQuantity) AS OrderQuantity 
FROM Gold.VW_SALES S
LEFT JOIN Silver.Cus_Info C ON S.CustomerKey=C.CustomerKey
GROUP BY S.CustomerKey,C.FirstName+' '+C.LastName
ORDER BY SUM(S.OrderQuantity) DESC



